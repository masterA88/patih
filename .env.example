# .env.example — copy to .env and fill in values
# See build-spec Section 5.3 and Section 5.7 for usage context
# NEVER commit .env — it is gitignored

# =============================================================================
# LLM Provider Keys (all free tier)
# =============================================================================

# Gemini AI Studio: https://aistudio.google.com/app/apikey
# Free tier: 10 RPM / 1500 req/day (Gemini 2.5 Flash)
GEMINI_API_KEY=

# Groq Console: https://console.groq.com/
# Free tier: 30 RPM for Llama 3.3 70B Versatile
GROQ_API_KEY=

# Cerebras: https://inference-docs.cerebras.ai/
# Free tier: 30 RPM / 1M tokens/day (Qwen 3 32B)
CEREBRAS_API_KEY=

# OpenRouter: https://openrouter.ai/
# NOTE: deepseek/deepseek-r1:free endpoint discontinued (returns 404 as of eval-baseline-v3).
# OPENROUTER_API_KEY is retained here for Phase 2 when a working model slug is confirmed.
# Remove or replace with an active OpenRouter model before re-enabling in gateway.py.
OPENROUTER_API_KEY=

# =============================================================================
# Langfuse self-host (running via docker-compose on Oracle VM)
# =============================================================================

LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Langfuse Postgres (docker-compose internal — generate with: `openssl rand -hex 32`)
# All three can be random hex strings. They don't need to be remembered, just persistent.
LANGFUSE_DB_PASSWORD=
LANGFUSE_SECRET=
LANGFUSE_SALT=

# =============================================================================
# App configuration
# =============================================================================

APP_ENV=development
LOG_LEVEL=INFO

EMBEDDING_MODEL_PATH=./models/multilingual-e5-large-onnx-int8
CHROMA_PATH=./data/chroma
BM25_PATH=./data/bm25

CHATBOT_DOC_ID=permensos-8-2023
CHATBOT_DATA_DIR=./data
CHATBOT_MODELS_DIR=./models
